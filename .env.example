# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin auth (simple password auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Database
DATABASE_URL="file:./dev.db"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP (optional but recommended for emails)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=apikey_or_username
SMTP_PASS=your_password
SMTP_FROM=Your Name <no-reply@yourdomain.com>
# Optional TLS overrides (use only if needed)
# SMTP_SECURE=true
# SMTP_TLS_SERVERNAME=provider.hostname.example
# SMTP_TLS_REJECT_UNAUTHORIZED=false

# DeepL Translation API (free tier: 500k chars/month — https://www.deepl.com/pro#developer)
DEEPL_API_KEY=

# Google Analytics 4 (optional — omit or leave blank to disable tracking)
# Find your Measurement ID in GA4 > Admin > Data Streams > your stream > Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=
